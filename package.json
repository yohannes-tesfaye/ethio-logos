{
  "name": "ethio-logos",
  "version": "0.1.1",
  "description": "A premium collection of high-quality Ethiopian brand logos as fully-customizable React & TypeScript components.",
  "type": "module",
  "sideEffects": false,
  "module": "dist/index.esm.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js"
    }
  },
  "keywords": [
    "ethiopian logos",
    "ethio-logos",
    "ethio icons",
    "ethiopian icons",
    "ethiopian brands",
    "ethiopia",
    "ethiopian",
    "logos",
    "svg",
    "react",
    "typescript",
    "brand",
    "components"
  ],
  "author": "Yohannes Tesfaye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yohannes-tesfaye/ethio-logos.git"
  },
  "bugs": {
    "url": "https://github.com/yohannes-tesfaye/ethio-logos/issues"
  },
  "homepage": "https://github.com/yohannes-tesfaye/ethio-logos#readme",
  "scripts": {
    "prebuild": "rimraf src && rimraf dist",
    "build": "npm run svgr && rollup -c && tsc src/index.ts --emitDeclarationOnly --declaration --declarationDir dist --noEmit false --jsx react-jsx --module esnext --moduleResolution bundler --esModuleInterop --target esnext",
    "build:web": "next build",
    "svgr": "svgr --icon --title-prop -d src assets",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "rollup-plugin-filesize": "^10.0.0",
    "tailwindcss": "^4",
    "tslib": "^2.8.1",
    "typescript": "^5"
  }
}
